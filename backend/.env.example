# Database
DATABASE_URL="postgresql://haitech:haitech_password@localhost:5432/haitech_crm?schema=public"

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Admin seed (optional)
ADMIN_EMAIL=admin@haitech.co.il
ADMIN_PASSWORD=admin123
ADMIN_NAME=מנהל מערכת

# WhatsApp inbound router (optional)
# Keep Meta webhook pointed at the CRM and forward one phone-number stream to an external agent.
# Disabled unless WA_INBOUND_FORWARD_WEBHOOK_URL is set.
WA_INBOUND_FORWARD_PHONE_NUMBER_ID=
WA_INBOUND_FORWARD_WEBHOOK_URL=
WA_INBOUND_FORWARD_SECRET=
WA_INBOUND_FORWARD_TIMEOUT_MS=5000
